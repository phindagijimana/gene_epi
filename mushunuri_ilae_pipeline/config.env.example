# Copy to config.env and adjust paths.

# Root of this pipeline (auto-set if you `source` from elsewhere)
export PIPE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Where MAGMA binary + reference + annotations live
export MAGMADIR="${PIPE_ROOT}/tools/magma"

# ILAE3: folder containing decompressed summary statistic files (after final_sumstats.zip)
export ILAE_SUMSTATS_DIR="${PIPE_ROOT}/data/ilae3_sumstats"

# Auto-picked by 04_prepare if these exist; override if needed
export ILAE_GGE_GWAS=""
export ILAE_FE_GWAS=""
export ILAE_ALL_GWAS=""

# Effective sample size column: if your file has no per-SNP N, scripts use this default (paper ~82k total)
export ILAE_DEFAULT_N=82500

# Threads for PLINK/MAGMA where applicable
export N_THREADS=8
